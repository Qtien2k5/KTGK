@{
    ViewData["Title"] = "Tải lên đề TOEIC";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            TẢI LÊN & BÓC TÁCH ĐỀ THI TOEIC READING
        </div>

        <div class="card-body">

            <form asp-action="Upload" method="post" enctype="multipart/form-data">

                <!-- Thông tin chung -->
                <h5>1. Thông tin chung</h5>

                <div class="row mb-3">

                    <div class="col-md-8">
                        <label class="form-label">Tên đề thi *</label>
                        <input type="text" name="Title" class="form-control"
                               placeholder="VD: TOEIC Reading Test 01 – ETS 2024">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Thời gian (Phút) *</label>
                        <input type="number" name="Duration" class="form-control" value="75">
                    </div>

                </div>

                <div class="mb-4">
                    <label class="form-label">Mô tả ngắn</label>
                    <textarea name="Description" class="form-control"
                              placeholder="Ghi chú thêm về đề thi này..."></textarea>
                </div>

                <!-- Upload File -->
                <h5>2. Dữ liệu đầu vào</h5>

                <div class="border border-primary rounded p-5 text-center"
                     style="background:#f8f9fa">

                    <p class="mb-2 fw-bold">File Đề Thi (.docx)</p>

                    <input type="file" name="file"
                           class="form-control w-50 mx-auto"
                           accept=".docx">

                    <p class="text-muted mt-3">
                        Click để chọn file Word (.docx)
                        <br>
                        Phải tuân thủ đúng định dạng thẻ Tags
                    </p>

                </div>

                <!-- Buttons -->
                <div class="mt-4 d-flex justify-content-between">

                    <button type="button" class="btn btn-secondary">
                        ← Quay lại
                    </button>

                    <div>

                        <button type="button" class="btn btn-warning">
                            Demo File Lỗi
                        </button>

                        <button type="button" class="btn btn-success">
                            Demo File Chuẩn
                        </button>

                        <button type="submit" class="btn btn-primary">
                            Bắt đầu Tải lên & Xử lý
                        </button>

                    </div>

                </div>

            </form>

        </div>
    </div>

</div>