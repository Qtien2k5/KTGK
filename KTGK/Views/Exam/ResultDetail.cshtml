@{
    ViewData["Title"] = "Upload Đề Thi";
}

<div class="upload-wrapper">
    <div class="upload-card">
        <div class="upload-icon">📄</div>
        <h2>Upload Đề Thi TOEIC</h2>
        <p class="upload-subtitle">Chỉ hỗ trợ file <strong>.docx</strong> đúng định dạng</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">⚠️ @ViewBag.Error</div>
        }

        <form method="post" action="/Upload/Upload" enctype="multipart/form-data">
            <div class="file-drop-zone" id="dropZone">
                <input type="file" name="file" id="fileInput" accept=".docx" hidden />
                <div class="drop-content" onclick="document.getElementById('fileInput').click()">
                    <span class="drop-icon">☁️</span>
                    <p>Kéo thả file vào đây hoặc <span class="link">click để chọn</span></p>
                    <p id="fileName" class="file-name"></p>
                </div>
            </div>

            <div class="form-fields">
                <div class="field-group">
                    <label>Tên đề thi <span class="optional">(để trống = lấy từ file)</span></label>
                    <input type="text" name="customTitle" placeholder="VD: TOEIC Reading Test 01 - ETS 2024" />
                </div>
                <div class="field-row">
                    <div class="field-group">
                        <label>Thời gian làm bài (phút)</label>
                        <input type="number" name="customDuration" placeholder="75" min="1" max="300" />
                    </div>
                    <div class="field-group">
                        <label>Ghi chú</label>
                        <input type="text" name="customDescription" placeholder="VD: Đề thi thử tháng 3/2026" />
                    </div>
                </div>
            </div>

            <button type="submit" class="btn-upload">
                🚀 Upload & Tạo Đề Thi
            </button>
        </form>

        <div class="format-hint">
            <h4>📋 Định dạng file chuẩn:</h4>
            <code>[EXAM_TITLE] Tên đề thi</code>
            <code>[EXAM_TIME] 75</code>
            <code>[PART: 5]</code>
            <code>[Q:101] [SHUFFLE:TRUE]</code>
            <code>Nội dung câu hỏi</code>
            <code>[A] Đáp án A &nbsp; [KEY:B]</code>
        </div>
    </div>
</div>

<style>
    .upload-wrapper {
        display: flex;
        justify-content: center;
        padding: 40px 16px;
    }

    .upload-card {
        background: white;
        border-radius: 20px;
        padding: 48px 40px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        text-align: center;
    }

    .upload-icon {
        font-size: 48px;
        margin-bottom: 12px;
    }

    .upload-card h2 {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 6px;
    }

    .upload-subtitle {
        color: #64748b;
        margin-bottom: 24px;
    }

    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 20px;
    }

    .file-drop-zone {
        border: 2px dashed #cbd5e1;
        border-radius: 14px;
        padding: 36px 20px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 20px;
        background: #f8fafc;
    }

        .file-drop-zone:hover {
            border-color: #3b82f6;
            background: #eff6ff;
        }

    .drop-icon {
        font-size: 36px;
        display: block;
        margin-bottom: 8px;
    }

    .drop-content p {
        color: #64748b;
        margin: 4px 0;
    }

    .link {
        color: #3b82f6;
        font-weight: 600;
    }

    .file-name {
        color: #3b82f6;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .form-fields {
        text-align: left;
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .field-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #475569;
        }

        .field-group .optional {
            font-weight: 400;
            color: #94a3b8;
            font-size: 0.78rem;
        }

        .field-group input {
            padding: 10px 14px;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            font-size: 0.9rem;
            outline: none;
            transition: border 0.2s;
        }

            .field-group input:focus {
                border-color: #3b82f6;
            }

    .btn-upload {
        width: 100%;
        background: linear-gradient(135deg, #3b82f6, #6366f1);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        .btn-upload:hover {
            opacity: 0.88;
        }

    .format-hint {
        text-align: left;
        background: #f1f5f9;
        border-radius: 12px;
        padding: 16px 20px;
        margin-top: 24px;
        font-size: 0.82rem;
    }

        .format-hint h4 {
            margin: 0 0 10px;
            color: #475569;
        }

        .format-hint code {
            display: block;
            color: #0f172a;
            font-family: monospace;
            line-height: 1.8;
        }
</style>

<script>
    document.getElementById('fileInput').addEventListener('change', function() {
        const name = this.files[0]?.name;
        document.getElementById('fileName').textContent = name ? '✅ ' + name : '';
    });
</script>
