@model List<KTGK.ViewModels.ExamViewModel>
@using KTGK.ViewModels
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<div class="container mt-4">

    <h3 class="mb-4 text-center">📚 Thư viện Đề thi TOEIC Reading</h3>

    <div class="row">

        @foreach (var exam in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-header bg-primary text-white text-center">
                        MỚI
                    </div>

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@exam.Title</h5>

                        <p class="text-muted">
                            @exam.Description
                        </p>

                        <div class="d-flex justify-content-between small text-muted mb-2">
                            <span>⏱ @exam.Duration phút</span>
                            <span>📄 100 Câu</span>
                        </div>

                        <p class="text-success mb-2">
                            👨‍🎓 @exam.StudentCount người đã làm
                        </p>

                        <hr />

                        <!-- Nút làm bài -->
                        <a asp-controller="Exam"
                           asp-action="DoExam"
                           asp-route-id="@exam.ExamId"
                           class="btn btn-primary w-100 mb-2">
                            Bắt đầu làm bài
                        </a>

                        <!-- Chỉ Teacher mới thấy -->
                        @if (Context.Session.GetString("role") == "Teacher")
                        {
                            <a asp-controller="Exam"
                               asp-action="Edit"
                               asp-route-id="@exam.ExamId"
                               class="btn btn-warning">
                                Sửa
                            </a>

                            <a asp-controller="Exam"
                               asp-action="Delete"
                               asp-route-id="@exam.ExamId"
                               class="btn btn-danger w-100"
                               onclick="return confirm('Xóa đề này?')">
                                Xóa
                            </a>
                        }

                    </div>

                </div>

            </div>
        }

    </div>

</div>