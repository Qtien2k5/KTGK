@{
    var username = Context.Session.GetString("username");
    var role = Context.Session.GetString("role");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] -KTGK </title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KTGK.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">KTGK</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (role == "Teacher")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Upload" asp-action="Index">📤 Upload Đề</a>
                            </li>
                        }
                    </ul>
                    @if (!string.IsNullOrEmpty(username))
                    {
                        <ul class="navbar-nav ms-auto align-items-center">
                            <li class="nav-item">
                                <span class="navbar-text me-3 text-dark">
                                    Xin chào, <strong>@username</strong>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-secondary btn-sm"
                                   asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
                <a class="navbar-brand" href="#"></a>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav ms-auto">
                        @if (Context.Session.GetString("role") == "Student")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Student/Dashboard">🏠 Dashboard</a>
                            </li>
                        }
                        else if (Context.Session.GetString("role") == "Teacher")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Teacher/Dashboard">🏠 Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Exam/Library">📚 Thư viện</a>
                            </li>
                        }
                        @if (Context.Session.GetString("username") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-warning">
                                    👤 @Context.Session.GetString("username")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" href="/Auth/Logout">Đăng xuất</a>
                            </li>
                        }
                    </ul>
                </div>
            </nav>
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - KTGK - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
